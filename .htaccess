# Configuración para SPA React
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # NO reescribir archivos estáticos (JS, CSS, imágenes, etc.)
  RewriteCond %{REQUEST_URI} \.(js|css|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|eot|json)$ [NC]
  RewriteRule ^ - [L]
  
  # NO reescribir si el archivo o directorio existe
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Redirigir todo lo demás a index.html
  RewriteRule ^ index.html [L]
</IfModule>

# Habilitar compresión GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache control
<IfModule mod_expires.c>
  ExpiresActive On
  
  # HTML - SIN CACHÉ (forzar recarga siempre)
  ExpiresByType text/html "access plus 0 seconds"
  
  # Imágenes - 1 año
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  
  # CSS y JS - 1 año (Vite genera hashes únicos)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/x-javascript "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  ExpiresDefault "access plus 2 days"
</IfModule>

# Headers adicionales para forzar no-cache en HTML
<IfModule mod_headers.c>
  # HTML - Forzar no-cache (incluye headers para móviles)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0, s-maxage=0, proxy-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
    # Headers adicionales para Safari iOS y Chrome Android
    Header set X-UA-Compatible "IE=edge"
    Header unset ETag
    Header unset Last-Modified
  </FilesMatch>
  
  # CSS y JS con hash - caché largo
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
