# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_EXCEL_URL: URL del archivo Excel desde Google Sheets o Hostinger
# Google Sheets: https://docs.google.com/spreadsheets/d/TU_ID_AQUI/export?format=xlsx
# Hostinger: https://tudominio.com/data/productos.xlsx
# Dejar vacío para usar la URL por defecto configurada en src/config.ts
VITE_EXCEL_URL=""

# Google Cloud Console - API Credentials (para edición directa en Admin Panel)
# IMPORTANTE: Solo necesarias si quieres editar precios directamente en Google Sheets
# Obtener en: https://console.cloud.google.com/apis/credentials

# VITE_AUTHORIZED_EMAILS: Lista de emails autorizados para acceder al admin panel
# Separar múltiples emails con comas, sin espacios
# Ejemplo: "admin@example.com,usuario2@gmail.com,usuario3@company.com"
# Dejar vacío para permitir cualquier email (no recomendado)
VITE_AUTHORIZED_EMAILS=""
# 
# Step 1: Crear proyecto en Google Cloud Console
# Step 2: Habilitar Google Sheets API
# Step 3: Crear credenciales OAuth 2.0
# Step 4: Agregar tu dominio a "Authorized JavaScript origins"
# Step 5: Copiar Client ID y API Key aquí
VITE_GOOGLE_CLIENT_ID=""
VITE_GOOGLE_API_KEY=""

# Google Sheets - Spreadsheet Configuration
# ID del spreadsheet (extrae de la URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit)
# Nombre de la pestaña/hoja dentro del spreadsheet
VITE_GOOGLE_SPREADSHEET_ID=""
VITE_GOOGLE_SHEET_NAME="CVS"
